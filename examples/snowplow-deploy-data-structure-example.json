{
  "title": "Deploy Data Structure to Production",
  "description": "Example request and response for deploying a validated Snowplow event schema to the PROD environment",
  "request": {
    "method": "POST",
    "url": "https://console.snowplowanalytics.com/api/msc/v1/organizations/{organizationId}/data-structures/v1/deployment-requests",
    "headers": {
      "Authorization": "Bearer {jwt_access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "dataStructureHash": "a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4",
      "version": "1-0-1",
      "target": "PROD"
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "version": "1-0-1",
      "environment": "PROD",
      "deployedAt": "2026-05-02T14:30:00Z",
      "deployedBy": "data-engineer@example.com",
      "status": "success",
      "message": "Schema com.example/page_view/jsonschema/1-0-1 successfully deployed to PROD"
    }
  }
}
